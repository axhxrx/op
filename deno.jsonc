{
  "name": "@axhxrx/op",
  "version": "1.0.0",
  "exports": "./mod.ts",
  "license": "MIT",
  "tasks": {
    "check": "bun test && node --test *.test.ts && deno test -A && bunx tsc --noEmit && deno check mod.ts && deno lint && dprint fmt"
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true
  },
  "exclude": [
    ".claude",
    ".git",
    ".github",
    ".vscode",
    "CLAUDE.md",
    "bun.lock",
    "dprint.jsonc",
    "node_modules",
    "tsconfig.json",
    "*.examples.ts"
  ]
}